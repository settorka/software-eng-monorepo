@Settlement.Api_HostAddress = http://localhost:5032

GET {{Settlement.Api_HostAddress}}/health
Accept: application/json

###

POST {{Settlement.Api_HostAddress}}/api/v1/trades
Content-Type: application/json
Idempotency-Key: local-placeholder
X-Correlation-Id: local-placeholder

{
  "tradeId": "TRD-2026-000001",
  "tradeVersion": 1,
  "commodity": "POWER",
  "counterparty": "CP-001",
  "quantity": 1000,
  "unit": "MWH",
  "price": 85.25,
  "currency": "GBP",
  "tradeDate": "2026-07-17",
  "settlementDate": "2026-07-31"
}

###

GET {{Settlement.Api_HostAddress}}/api/v1/workflows
Accept: application/json

###

@WorkflowId = 00000000-0000-0000-0000-000000000000

GET {{Settlement.Api_HostAddress}}/api/v1/workflows/{{WorkflowId}}
Accept: application/json

###

POST {{Settlement.Api_HostAddress}}/api/v1/workflows/{{WorkflowId}}/execute
X-Correlation-Id: local-placeholder

###

POST {{Settlement.Api_HostAddress}}/api/v1/settlements/{{WorkflowId}}/approve
X-Correlation-Id: local-placeholder

###

POST {{Settlement.Api_HostAddress}}/api/v1/workflows/{{WorkflowId}}/retry
X-Correlation-Id: local-placeholder

###

POST {{Settlement.Api_HostAddress}}/api/v1/workflows/pump
X-Correlation-Id: local-placeholder
