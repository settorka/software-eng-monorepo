ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

API_HTTP_PORT=8080
ORACLE_PORT=1521
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_UI_PORT=16686
LOKI_PORT=3100
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROMETHEUS_PORT=8889

ORACLE_PASSWORD=settlement
ORACLE_APP_USER=settlement
ORACLE_APP_PASSWORD=settlement
ConnectionStrings__Oracle=User Id=settlement;Password=settlement;Data Source=oracle:1521/FREEPDB1

RABBITMQ_DEFAULT_USER=settlement
RABBITMQ_DEFAULT_PASS=settlement
RabbitMq__Host=rabbitmq
RabbitMq__Port=5672
RabbitMq__Username=settlement
RabbitMq__Password=settlement
RabbitMq__Exchange=settlement.events
RabbitMq__RoutingKey=payment.request.created
RabbitMq__TimeoutMilliseconds=5000

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

OperationalControls__IntakeEnabled=true
OperationalControls__WorkflowPumpEnabled=true
OperationalControls__OutboxDispatcherEnabled=true
OperationalControls__MaxPumpWorkflows=25
OperationalControls__OutboxBatchSize=25
OperationalControls__OutboxMaxAttempts=10
OperationalControls__PollIntervalMilliseconds=1000
OperationalControls__MaxRequestBodyBytes=65536
OperationalControls__DetailedErrors=true

Database__RunMigrationsOnStartup=true

Auth__Enabled=false
Auth__Authority=
Auth__Audience=
Auth__RequireHttpsMetadata=true
Auth__SigningKey=

OutboxPublisher__Mode=Logging
OutboxPublisher__MaxPayloadBytes=262144

LOG_LEVEL_DEFAULT=Information
LOG_LEVEL_MICROSOFT_ASPNETCORE=Warning
LOG_LEVEL_EF_COMMAND=Warning
