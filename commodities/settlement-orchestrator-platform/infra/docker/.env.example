ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

API_HTTP_PORT=8080
ORACLE_PORT=1521
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_UI_PORT=16686
LOKI_PORT=3100
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROMETHEUS_PORT=8889

ORACLE_PASSWORD=settlement
ORACLE_APP_USER=settlement
ORACLE_APP_PASSWORD=settlement
ConnectionStrings__Oracle=User Id=settlement;Password=settlement;Data Source=oracle:1521/FREEPDB1

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

OperationalControls__IntakeEnabled=true
OperationalControls__WorkflowPumpEnabled=true
OperationalControls__MaxPumpWorkflows=25
OperationalControls__PollIntervalMilliseconds=1000
OperationalControls__MaxRequestBodyBytes=65536
OperationalControls__DetailedErrors=true

LOG_LEVEL_DEFAULT=Information
LOG_LEVEL_MICROSOFT_ASPNETCORE=Warning
