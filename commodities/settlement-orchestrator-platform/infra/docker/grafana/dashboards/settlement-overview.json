{
  "title": "Settlement Overview",
  "uid": "settlement-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "API Up",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"settlement-api\"}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "timeseries",
      "title": "API Request Rate",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total[5m]))"
        }
      ],
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 9,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "API p95 Latency",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))"
        }
      ],
      "gridPos": {
        "x": 15,
        "y": 0,
        "w": 9,
        "h": 8
      }
    }
  ]
}
