ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OperationalControls__IntakeEnabled=true
OperationalControls__WorkflowPumpEnabled=true
OperationalControls__OutboxDispatcherEnabled=true
OperationalControls__MaxPumpWorkflows=25
OperationalControls__OutboxBatchSize=25
OperationalControls__OutboxMaxAttempts=10
OperationalControls__PollIntervalMilliseconds=1000
OperationalControls__MaxRequestBodyBytes=65536
OperationalControls__DetailedErrors=true
Database__RunMigrationsOnStartup=true
Auth__Enabled=false
Auth__Authority=
Auth__Audience=
Auth__RequireHttpsMetadata=true
OutboxPublisher__Mode=Logging
OutboxPublisher__Endpoint=
OutboxPublisher__ApiKey=
OutboxPublisher__TimeoutMilliseconds=5000
OutboxPublisher__MaxPayloadBytes=262144
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
Logging__LogLevel__Microsoft.EntityFrameworkCore.Database.Command=Warning
Serilog__MinimumLevel__Override__Microsoft.EntityFrameworkCore.Database.Command=Warning
